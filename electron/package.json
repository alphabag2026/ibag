{
  "name": "ibag",
  "version": "5.3.4",
  "description": "iBag - Smart Crypto Wallet & AI Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux AppImage",
    "build-win": "electron-builder --win portable",
    "build-all": "electron-builder --linux AppImage --win portable"
  },
  "author": "Alphabag",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.alphabag.ibag",
    "productName": "iBag",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "www/**/*",
      "icon.png"
    ],
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Finance"
    },
    "win": {
      "target": "portable",
      "icon": "icon.png",
      "sign": false,
      "signingHashAlgorithms": []
    },
    "forceCodeSigning": false
  }
}
